<?xml version="1.0" encoding="UTF-8"?>
<connections>
    <!-- lane 0: right turn + straight, lane 1: straight, lane 2: exclusive left.
         Exclusive left lanes make netconvert emit protected left-turn phases. -->
    <connection from="N_in" fromLane="0" to="W_out" toLane="0"/>
    <connection from="N_in" fromLane="0" to="S_out" toLane="0"/>
    <connection from="N_in" fromLane="1" to="S_out" toLane="1"/>
    <connection from="N_in" fromLane="2" to="E_out" toLane="2"/>

    <connection from="S_in" fromLane="0" to="E_out" toLane="0"/>
    <connection from="S_in" fromLane="0" to="N_out" toLane="0"/>
    <connection from="S_in" fromLane="1" to="N_out" toLane="1"/>
    <connection from="S_in" fromLane="2" to="W_out" toLane="2"/>

    <connection from="E_in" fromLane="0" to="N_out" toLane="0"/>
    <connection from="E_in" fromLane="0" to="W_out" toLane="0"/>
    <connection from="E_in" fromLane="1" to="W_out" toLane="1"/>
    <connection from="E_in" fromLane="2" to="S_out" toLane="2"/>

    <connection from="W_in" fromLane="0" to="S_out" toLane="0"/>
    <connection from="W_in" fromLane="0" to="E_out" toLane="0"/>
    <connection from="W_in" fromLane="1" to="E_out" toLane="1"/>
    <connection from="W_in" fromLane="2" to="N_out" toLane="2"/>
</connections>
